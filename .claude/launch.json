{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "uvicorn", "Backend.main:app", "--reload", "--host", "127.0.0.1", "--port", "8080", "--app-dir", "src"],
      "port": 8080,
      "autoPort": false
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "apps/nextjs-app",
      "autoPort": false
    }
  ]
}
