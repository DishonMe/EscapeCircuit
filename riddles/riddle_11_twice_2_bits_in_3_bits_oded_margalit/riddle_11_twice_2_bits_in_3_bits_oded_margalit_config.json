      "NOT",
      "OR",
      "XOR",
      "NAND",
      "NOR"
    ],
    "inputs": [
      "x0",
      "x1",
      "x2"
    ],
    "outputs": [
      "out1 (MSB)",
      "out0 (LSB)"
    ],
    "min_cycles": null,
    "max_cycles": null,
    "total_gate_count": null,
    "allow_arsenal": true,
    "board": {
      "rows": 10,
      "cols": 20
    }
  },
  "test_cases": [
