{
  "puzzle": {
    "name": "Sequential Binary Adder Quiz",
    "description": "Design a sequential circuit that adds binary numbers bit by bit over multiple clock cycles using DFF gates for state. Each cycle receives one input bit X, and produces sum (OUT) and carry (C_out) outputs.",
    "budget": 15,
    "creator_budget": 7,
    "time_limit_seconds": null,
    "difficulty": "MEDIUM",
    "default_gate_set": [
      "AND",
      "XOR",
      "OR",
      "DFF",
      "NAND"
    ],
    "input": [
      "X"
    ],
    "state": [
      "D1",
      "D2"
    ],
    "outputs": [
      "OUT",
      "C_out"
    ],
    "initial_state": {
      "D1": 0,
      "D2": 0
    },
    "type": "sequential_riddle",
    "total_gate_count": null,
    "min_cycles": 3,
    "max_cycles": 3,
    "allow_arsenal": true,
    "riddle_base_name": "riddle_03_sequential_adder",
    "clues": [
      "Use the two DFF outputs (D1, D2) as your previous-bit memory — that's the carry from the prior cycle.",
      "OUT each cycle is X XOR carry_in. The new carry is the majority of X and carry_in.",
      "Two DFFs are enough: one for the saved carry, one optional for input parity tracking."
    ]
  },
  "test_cases": [
    {
      "kind": "stream",
      "input_stream": [
        1,
        1,
        1
      ],
      "expected_output_stream": {
        "OUT": [
          1,
          0,
          1
        ],
        "C_out": [
          0,
          1,
          1
        ]
      }
    },
    {
      "kind": "stream",
      "input_stream": [
        0,
        0,
        0
      ],
      "expected_output_stream": {
        "OUT": [
          0,
          0,
          0
        ],
        "C_out": [
          0,
          0,
          0
        ]
      }
    },
    {
      "kind": "stream",
      "input_stream": [
        1,
        0,
        0
      ],
      "expected_output_stream": {
        "OUT": [
          1,
          1,
          1
        ],
        "C_out": [
          0,
          0,
          0
        ]
      }
    }
  ]
}